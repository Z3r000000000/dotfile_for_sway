## Местоположение и размеры
max-visible=5
sort=-time
layer=top
anchor=top-right
margin=20
padding=15
width=300
height=100
border-size=2
border-radius=15
icons=1
max-icon-size=48

## Шрифты и цвета (Палитра Tokyo Night)
font=JetBrainsMono Nerd Font 10
background-color=#24283b
text-color=#c0caf5
border-color=#7aa2f7
progress-color=over #3b4261

## Поведение
default-timeout=5000
ignore-timeout=0
group-by=appname

## Стили для разных уровней важности
[urgency=low]
border-color=#3b4261
default-timeout=2000

[urgency=normal]
border-color=#7aa2f7

[urgency=critical]
border-color=#f7768e
text-color=#f7768e
default-timeout=0

## Стиль для конкретных приложений (например, Spotify/музыка)
[app-name=Spotify]
border-color=#9ece6a