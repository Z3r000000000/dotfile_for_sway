# --- Секция Main ---
[main]
# Шрифт (обязательно Nerd Font для иконок)
font=JetBrainsMono Nerd Font:size=10
# Внутренние отступы от краев (чтобы текст не лип к рамке)
pad=15x15
# Оболочка (лучше оставить пустой, подхватит системную, например fish)
shell=/usr/bin/fish

# --- Секция Курсор ---
[cursor]
style=block
color=1a1b26 c0caf5
blink=yes

# --- Секция Цвета (Tokyo Night) ---
[colors]
alpha=0.93  # Небольшая прозрачность для стиля
background=1a1b26
foreground=c0caf5

## Regular colors
regular0=15161e  # black
regular1=f7768e  # red
regular2=9ece6a  # green
regular3=e0af68  # yellow
regular4=7aa2f7  # blue
regular5=bb9af7  # magenta
regular6=7dcfff  # cyan
regular7=a9b1d6  # white

## Bright colors
bright0=414868   # bright black
bright1=f7768e   # bright red
bright2=9ece6a   # bright green
bright3=e0af68   # bright yellow
bright4=7aa2f7   # bright blue
bright5=bb9af7   # bright magenta
bright6=7dcfff   # bright cyan
bright7=c0caf5   # bright white

# --- Секция Scrollback (прокрутка) ---
[scrollback]
lines=5000

# --- Секция URL (клик по ссылкам) ---
[url]
launch=xdg-open ${url}
label-letters=sadfjklewcmpgh
osc8-underline=always

# --- Секция Mouse ---
[mouse]
hide-when-typing=yes